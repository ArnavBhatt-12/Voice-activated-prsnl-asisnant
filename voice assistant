class VoiceProcessor(QObject):
    """Handles all voice recognition and processing"""
    
    transcribed = pyqtSignal(str)  # Emits recognized text
    listening = pyqtSignal(bool)   # Emits listening state
    error = pyqtSignal(str)        # Emits errors
    
    def __init__(self):
        super().__init__()
        self.recognizer = sr.Recognizer()
        self.microphone = sr.Microphone()
        self.tts_engine = pyttsx3.init()
        
        # Configure TTS
        self.tts_engine.setProperty('rate', 150)
        self.tts_engine.setProperty('volume', 0.9)
        
        self.is_listening = False
        self.wake_word = "assistant"  # Wake word
        
    def setup_microphone(self):
        """Calibrate microphone noise levels"""
        try:
            with self.microphone as source:
                self.recognizer.adjust_for_ambient_noise(source, duration=1)
            return True
        except Exception as e:
            self.error.emit(f"Microphone setup error: {str(e)}")
            return False
    
    def listen_for_wake_word(self):
        """Continuously listen for wake word"""
        self.listening.emit(True)
        self.is_listening = True
        
        try:
            with self.microphone as source:
                while self.is_listening:
                    try:
                        # Listen with timeout
                        audio = self.recognizer.listen(source, timeout=1.0)
                        
                        # Use Google Speech Recognition
                        text = self.recognizer.recognize_google(audio).lower()
                        
                        # Check for wake word
                        if self.wake_word in text:
                            self.transcribed.emit(f"[Wake word detected] {text}")
                            self.listening.emit(False)
                            return True
                            
                    except sr.UnknownValueError:
                        pass  # Couldn't understand
                    except sr.RequestError:
                        pass  # API error
                        
        except Exception as e:
            self.error.emit(f"Listen error: {str(e)}")
            self.listening.emit(False)
        
        self.listening.emit(False)
        return False
    
    def listen_for_command(self, timeout=10):
        """Listen for a voice command after wake word"""
        try:
            with self.microphone as source:
                self.listening.emit(True)
                audio = self.recognizer.listen(source, timeout=timeout, phrase_time_limit=30)
                self.listening.emit(False)
                
                # Recognize speech
                text = self.recognizer.recognize_google(audio)
                return text
                
        except sr.UnknownValueError:
            self.error.emit("Couldn't understand the command")
            return None
        except sr.RequestError as e:
            self.error.emit(f"Speech recognition error: {str(e)}")
            return None
        except sr.WaitTimeoutError:
            self.error.emit("No speech detected")
            return None
    
    def speak(self, text):
        """Convert text to speech"""
        try:
            self.tts_engine.say(text)
            self.tts_engine.runAndWait()
        except Exception as e:
            self.error.emit(f"TTS Error: {str(e)}")
    
    def stop(self):
        """Stop listening"""
        self.is_listening = False


class TaskExecutor:
    """Execute various assistant tasks"""
    
    def __init__(self, api_key=None):
        self.weather_api_key = os.getenv('WEATHER_API_KEY', '')  # Get from .env
        self.news_api_key = os.getenv('NEWS_API_KEY', '')
        self.reminders = {}  # Store reminders
        self.timers = {}     # Store timers
        
        # Initialize Claude client
        self.client = Anthropic(api_key=api_key or os.getenv('ANTHROPIC_API_KEY'))
        self.conversation_history = []
    
    def get_weather(self, city="auto"):
        """Fetch weather data"""
        try:
            if city == "auto":
                # Get user's location
                ip_response = requests.get('https://ipapi.co/json/', timeout=5)
                city = ip_response.json().get('city', 'New York')
            
            if not self.weather_api_key:
                return "Weather API key not configured. Please set WEATHER_API_KEY."
            
            url = f"https://api.openweathermap.org/data/2.5/weather"
            params = {
                'q': city,
                'appid': self.weather_api_key,
                'units': 'metric'
            }
            
            response = requests.get(url, params=params, timeout=5)
            data = response.json()
            
            if response.status_code == 200:
                temp = data['main']['temp']
                description = data['weather'][0]['description']
                humidity = data['main']['humidity']
                wind_speed = data['wind']['speed']
                
                weather_text = (
                    f"Weather in {city}: {description.capitalize()}, "
                    f"{temp}°C, Humidity {humidity}%, Wind {wind_speed} m/s"
                )
                return weather_text
            else:
                return f"Could not fetch weather: {data.get('message', 'Unknown error')}"
                
        except Exception as e:
            return f"Weather error: {str(e)}"
    
    def get_news(self, category='general'):
        """Fetch latest news"""
        try:
            if not self.news_api_key:
                return "News API key not configured. Please set NEWS_API_KEY."
            
            url = f"https://newsapi.org/v2/top-headlines"
            params = {
                'category': category,
                'country': 'us',
                'apiKey': self.news_api_key,
                'pageSize': 3
            }
            
            response = requests.get(url, params=params, timeout=5)
            data = response.json()
            
            if data.get('articles'):
                news_summary = "Top news:\n"
                for i, article in enumerate(data['articles'][:3], 1):
                    news_summary += f"{i}. {article['title']}\n"
                return news_summary
            else:
                return "No news articles found."
                
        except Exception as e:
            return f"News error: {str(e)}"
    
    def set_reminder(self, text, minutes=10):
        """Set a reminder"""
        reminder_id = str(datetime.now().timestamp())
        reminder_time = datetime.now() + timedelta(minutes=minutes)
        self.reminders[reminder_id] = {
            'text': text,
            'time': reminder_time,
            'notified': False
        }
        return f"Reminder set for {minutes} minutes from now: {text}"
    
    def set_timer(self, duration_seconds):
        """Set a timer"""
        timer_id = str(datetime.now().timestamp())
        self.timers[timer_id] = {
            'duration': duration_seconds,
            'start_time': datetime.now(),
            'completed': False
        }
        return f"Timer set for {duration_seconds} seconds"
    
    def get_time(self):
        """Get current time"""
        return datetime.now().strftime("%I:%M %p")
    
    def get_date(self):
        """Get current date"""
        return datetime.now().strftime("%A, %B %d, %Y")
    
    def process_command_with_ai(self, user_command):
        """Use Claude to intelligently process commands"""
        # Add user message to history
        self.conversation_history.append({
            "role": "user",
            "content": user_command
        })
        
        # System prompt for the assistant
        system_prompt = """You are a helpful voice-activated desktop assistant, similar to Siri or Alexa.
        
The user is speaking to you via voice commands. Keep responses concise (1-2 sentences max) and natural.

You have access to these functions:
- get_weather(city='auto'): Get weather information
- get_news(category='general'): Get latest news
- set_reminder(text, minutes=10): Set a reminder
- set_timer(duration_seconds): Set a timer
- get_time(): Get current time
- get_date(): Get current date
- open_application(name): Open an application
- tell_joke(): Tell a random joke
- search_web(query): Search the web

When the user asks for a task, indicate which function should be called in your response.
Format: [FUNCTION: function_name(param1, param2)]

Always be helpful, concise, and conversational. Don't break character."""
        
        try:
            response = self.client.messages.create(
                model="claude-opus-4-6",
                max_tokens=500,
                system=system_prompt,
                messages=self.conversation_history
            )
            
            assistant_message = response.content[0].text
            
            # Add to history
            self.conversation_history.append({
                "role": "assistant",
                "content": assistant_message
            })
            
            # Keep conversation history manageable
            if len(self.conversation_history) > 20:
                self.conversation_history = self.conversation_history[-20:]
            
            return assistant_message
            
        except Exception as e:
            return f"Error processing command: {str(e)}"
    
    def execute_task(self, command):
        """Execute a task based on the command"""
        command_lower = command.lower()
        
        # Route to appropriate function
        if 'weather' in command_lower:
            return self.get_weather()
        elif 'news' in command_lower:
            return self.get_news()
        elif 'time' in command_lower:
            return self.get_time()
        elif 'date' in command_lower:
            return self.get_date()
        elif 'reminder' in command_lower or 'remind' in command_lower:
            # Parse reminder time if mentioned
            return self.set_reminder("Reminder", 10)
        elif 'timer' in command_lower:
            # Parse duration if mentioned
            return self.set_timer(60)
        else:
            # Use AI for intelligent processing
            return self.process_command_with_ai(command)


class VoiceAssistantApp(QMainWindow):
    """Main application window"""
    
    def __init__(self):
        super().__init__()
        self.setWindowTitle("Voice Assistant")
        self.setGeometry(100, 100, 600, 500)
        
        # Core components
        self.voice_processor = VoiceProcessor()
        self.task_executor = TaskExecutor()
        
        # Threading
        self.voice_thread = None
        self.listen_thread = None
        
        # UI Setup
        self.init_ui()
        self.setup_signals()
        
        # Start listening in background
        self.start_listening_thread()
    
    def init_ui(self):
        """Initialize user interface"""
        central_widget = QWidget()
        self.setCentralWidget(central_widget)
        
        layout = QVBoxLayout()
        
        # Header
        title = QLabel("🎤 Voice Assistant")
        title.setFont(QFont("Arial", 20, QFont.Weight.Bold))
        layout.addWidget(title)
        
        # Status
        self.status_label = QLabel("Listening for wake word: 'Assistant'")
        self.status_label.setStyleSheet("color: #666; font-size: 12px;")
        layout.addWidget(self.status_label)
        
        # Listen indicator
        self.indicator_label = QLabel("🔴 Ready")
        self.indicator_label.setStyleSheet("font-size: 14px; color: green;")
        layout.addWidget(self.indicator_label)
        
        # Transcript display
        self.transcript_display = QTextEdit()
        self.transcript_display.setReadOnly(True)
        self.transcript_display.setMinimumHeight(250)
        layout.addWidget(self.transcript_display)
        
        # Response display
        self.response_display = QTextEdit()
        self.response_display.setReadOnly(True)
        self.response_display.setMinimumHeight(100)
        layout.addWidget(self.response_display)
        
        # Controls
        button_layout = QHBoxLayout()
        
        self.test_button = QPushButton("🎙️ Test Command")
        self.test_button.clicked.connect(self.test_command)
        button_layout.addWidget(self.test_button)
        
        self.stop_button = QPushButton("⏹️ Stop")
        self.stop_button.clicked.connect(self.stop_assistant)
        button_layout.addWidget(self.stop_button)
        
        layout.addLayout(button_layout)
        
        central_widget.setLayout(layout)
        
        # Styling
        self.setStyleSheet("""
            QMainWindow {
                background-color: #f5f5f5;
            }
            QTextEdit {
                border: 1px solid #ddd;
                border-radius: 5px;
                padding: 10px;
                background-color: white;
            }
            QPushButton {
                background-color: #4CAF50;
                color: white;
                border: none;
                padding: 10px 20px;
                border-radius: 5px;
                font-weight: bold;
                min-height: 40px;
            }
            QPushButton:hover {
                background-color: #45a049;
            }
            QPushButton:pressed {
                background-color: #3d8b40;
            }
        """)
    
    def setup_signals(self):
        """Connect signals"""
        self.voice_processor.transcribed.connect(self.on_transcribed)
        self.voice_processor.listening.connect(self.on_listening_state)
        self.voice_processor.error.connect(self.on_error)
    
    def start_listening_thread(self):
        """Start continuous listening thread"""
        if not self.voice_processor.setup_microphone():
            self.on_error("Failed to setup microphone")
            return
        
        self.listen_thread = threading.Thread(self.listening_loop, daemon=True)
        self.listen_thread.start()
    
    def listening_loop(self):
        """Main listening loop"""
        while True:
            try:
                # Listen for wake word
                if self.voice_processor.listen_for_wake_word():
                    # Wake word detected, now listen for command
                    self.response_display.setText("🎤 Listening for command...")
                    command = self.voice_processor.listen_for_command(timeout=10)
                    
                    if command:
                        self.transcript_display.setText(f"Command: {command}")
                        
                        # Process command
                        response = self.task_executor.execute_task(command)
                        self.response_display.setText(f"Response:\n{response}")
                        
                        # Speak response
                        self.voice_processor.speak(response)
                        
                        # Wait before listening for wake word again
                        time.sleep(1)
                
                time.sleep(0.1)
                
            except Exception as e:
                self.on_error(f"Listening loop error: {str(e)}")
                time.sleep(1)
    
    def test_command(self):
        """Test command without wake word"""
        self.response_display.setText("🎤 Say a command...")
        command = self.voice_processor.listen_for_command(timeout=10)
        
        if command:
            self.transcript_display.setText(f"Command: {command}")
            response = self.task_executor.execute_task(command)
            self.response_display.setText(f"Response:\n{response}")
            self.voice_processor.speak(response)
    
    def on_transcribed(self, text):
        """Handle transcribed text"""
        self.transcript_display.append(f"> {text}")
    
    def on_listening_state(self, is_listening):
        """Handle listening state change"""
        if is_listening:
            self.indicator_label.setText("🔴 Listening...")
            self.indicator_label.setStyleSheet("font-size: 14px; color: red;")
        else:
            self.indicator_label.setText("🟢 Ready")
            self.indicator_label.setStyleSheet("font-size: 14px; color: green;")
    
    def on_error(self, error_text):
        """Handle errors"""
        self.status_label.setText(f"Error: {error_text}")
        self.response_display.setText(f"❌ {error_text}")
    
    def stop_assistant(self):
        """Stop the assistant"""
        self.voice_processor.stop()
        self.close()
    
    def closeEvent(self, event):
        """Handle window close"""
        self.voice_processor.stop()
        event.accept()


def main():
    app = QApplication(sys.argv)
    window = VoiceAssistantApp()
    window.show()
    sys.exit(app.exec())


if __name__ == "__main__":
    main()
