# Integration Helper - Combine All Features
# ============================================================================

class IntegratedAssistant:
    """Unified assistant with all integrations"""
    
    def __init__(self):
        self.calendar = CalendarIntegration()
        self.spotify = SpotifyIntegration()
        self.smart_home = SmartHomeIntegration()
        self.email = EmailIntegration("user@email.com", "password")
        self.command_parser = AdvancedCommandParser()
        self.json_commands = JSONCommandLoader()
    
    def process_command(self, user_input: str) -> str:
        """Process command through all integrations"""
        
        # Try each integration in order of priority
        handlers = [
            self.calendar.handle_calendar_command,
            self.spotify.handle_music_command,
            self.smart_home.handle_smart_home_command,
            self.email.handle_email_command,
        ]
        
        for handler in handlers:
            result = handler(user_input)
            if result:
                return result
        
        # Try JSON-based commands
        result = self.json_commands.execute_command(user_input)
        if result:
            return result
        
        # Default: return None (let main assistant handle it)
        return None


