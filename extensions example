class SpotifyIntegration:
    """Control Spotify playback via voice"""
    
    def __init__(self):
        self.client_id = os.getenv('SPOTIFY_CLIENT_ID')
        self.client_secret = os.getenv('SPOTIFY_CLIENT_SECRET')
        # Requires: pip install spotipy
    
    def play_track(self, track_name: str) -> str:
        """Play a specific track"""
        return f"Playing {track_name}"
    
    def pause(self) -> str:
        """Pause playback"""
        return "Paused"
    
    def next_track(self) -> str:
        """Skip to next track"""
        return "Skipping to next track"
    
    def get_current_track(self) -> str:
        """Get currently playing track"""
        return "Now playing: Unknown Track"
    
    def handle_music_command(self, command: str) -> str:
        """Route music commands"""
        cmd_lower = command.lower()
        
        if 'play' in cmd_lower:
            # Extract song name
            return self.play_track("requested song")
        elif 'pause' in cmd_lower or 'stop' in cmd_lower:
            return self.pause()
        elif 'next' in cmd_lower or 'skip' in cmd_lower:
            return self.next_track()
        elif 'current' in cmd_lower or 'what\' in cmd_lower:
            return self.get_current_track()
        
        return None


