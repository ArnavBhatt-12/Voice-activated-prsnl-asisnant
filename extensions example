class CalendarIntegration:
    """Integrate with Google Calendar"""
    
    def __init__(self, api_key=None):
        self.api_key = api_key or os.getenv('GOOGLE_CALENDAR_API_KEY')
        # Requires: pip install google-auth-oauthlib google-auth-httplib2 google-api-python-client
    
    def get_upcoming_events(self, max_results=5):
        """Fetch upcoming calendar events"""
        # This is a template - implement with Google Calendar API
        return [
            {'title': 'Team Meeting', 'time': '2:00 PM'},
            {'title': 'Code Review', 'time': '3:30 PM'},
        ]
    
    def add_event(self, title: str, time_str: str):
        """Add event to calendar"""
        # Template - implement with Google Calendar API
        return f"Added event '{title}' at {time_str}"
    
    def handle_calendar_command(self, command: str) -> str:
        """Handle calendar-related commands"""
        if 'my calendar' in command.lower() or 'upcoming' in command.lower():
            events = self.get_upcoming_events()
            if events:
                response = "Your upcoming events: "
                for event in events:
                    response += f"{event['title']} at {event['time']}, "
                return response
        return None


