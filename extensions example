# Example 3: Smart Home Control (IoT Devices)
# ============================================================================

class SmartHomeIntegration:
    """Control smart home devices"""
    
    def __init__(self):
        self.devices = {
            'light': {'status': 'off', 'brightness': 50},
            'thermostat': {'temperature': 72, 'mode': 'auto'},
            'lock': {'status': 'locked'},
        }
    
    def toggle_light(self, brightness=None) -> str:
        """Toggle smart light"""
        light = self.devices['light']
        
        if brightness:
            light['brightness'] = min(100, max(0, brightness))
            light['status'] = 'on'
            return f"Light set to {light['brightness']}% brightness"
        else:
            light['status'] = 'on' if light['status'] == 'off' else 'off'
            return f"Light turned {light['status'].upper()}"
    
    def set_temperature(self, temp: float) -> str:
        """Set thermostat temperature"""
        self.devices['thermostat']['temperature'] = temp
        return f"Thermostat set to {temp} degrees"
    
    def lock_door(self) -> str:
        """Lock the door"""
        self.devices['lock']['status'] = 'locked'
        return "Door is now locked"
    
    def unlock_door(self) -> str:
        """Unlock the door"""
        self.devices['lock']['status'] = 'unlocked'
        return "Door is now unlocked"
    
    def handle_smart_home_command(self, command: str) -> str:
        """Route smart home commands"""
        cmd_lower = command.lower()
        
        if 'light' in cmd_lower:
            if 'brightness' in cmd_lower or 'dim' in cmd_lower:
                # Extract brightness level
                return self.toggle_light(brightness=75)
            return self.toggle_light()
        
        elif 'temperature' in cmd_lower or 'thermostat' in cmd_lower:
            return self.set_temperature(72)
        
        elif 'lock' in cmd_lower:
            if 'unlock' in cmd_lower:
                return self.unlock_door()
            return self.lock_door()
        
        return None


