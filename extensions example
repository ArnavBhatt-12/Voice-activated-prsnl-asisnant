class AdvancedCommandParser:
    """Parse complex voice commands"""
    
    def __init__(self):
        self.registry = CustomCommandRegistry()
        self.reminder_manager = ReminderManager()
        self.setup_custom_commands()
    
    def setup_custom_commands(self):
        """Register custom command handlers"""
        # Smart reminder parsing
        self.registry.register(
            ['remind me', 'set reminder'],
            self.parse_smart_reminder
        )
        
        # Weather with location
        self.registry.register(
            ['weather in'],
            self.parse_weather_location
        )
        
        # Time calculations
        self.registry.register(
            ['how long'],
            self.parse_duration
        )
    
    @staticmethod
    def parse_smart_reminder(text: str) -> str:
        """Parse reminder with natural language"""
        import re
        
        # Extract time and reminder text
        # "remind me about the meeting in 30 minutes"
        # "remind me to call mom at 3 PM"
        
        time_match = re.search(r'(?:in\s+)?(\d+)\s+(?:minutes?|hours?|days?)', text, re.IGNORECASE)
        
        if time_match:
            duration = time_match.group(1)
            reminder_text = re.sub(r'remind me (?:to|about|of)?\s*', '', text, flags=re.IGNORECASE)
            return f"Reminder set: '{reminder_text}' in {duration} minutes"
        
        return "I didn't understand the reminder time"
    
    @staticmethod
    def parse_weather_location(text: str) -> str:
        """Parse weather for specific location"""
        import re
        
        # "what's the weather in New York"
        location_match = re.search(r'in\s+([A-Za-z\s]+?)(?:\?|$)', text)
        
        if location_match:
            location = location_match.group(1).strip()
            return f"Fetching weather for {location}"
        
        return "Please specify a location"
    
