class JSONCommandLoader:
    """Load commands from JSON configuration"""
    
    EXAMPLE_CONFIG = {
        "commands": [
            {
                "triggers": ["my schedule", "what's my day"],
                "handler": "get_day_summary",
                "response": "You have 5 meetings today"
            },
            {
                "triggers": ["favorite song", "play my music"],
                "handler": "play_favorite",
                "response": "Playing your favorite playlist"
            },
            {
                "triggers": ["status report"],
                "handler": "generate_report",
                "response": "Generating daily status report"
            }
        ]
    }
    
    def __init__(self, config_file: str = None):
        self.config = self.EXAMPLE_CONFIG
        if config_file and os.path.exists(config_file):
            self.load_from_file(config_file)
    
    def load_from_file(self, config_file: str):
        """Load commands from JSON file"""
        try:
            with open(config_file, 'r') as f:
                self.config = json.load(f)
        except Exception as e:
            print(f"Error loading config: {e}")
    
    def get_handler(self, user_input: str) -> Dict:
        """Find matching command handler"""
        user_input_lower = user_input.lower()
        
        for command in self.config.get('commands', []):
            for trigger in command.get('triggers', []):
                if trigger.lower() in user_input_lower:
                    return command
        
        return None
    
    def execute_command(self, user_input: str) -> str:
        """Execute command if found"""
        handler = self.get_handler(user_input)
        
        if handler:
            # In a real implementation, this would call actual handlers
            return handler.get('response', 'Command executed')
        
        return None


